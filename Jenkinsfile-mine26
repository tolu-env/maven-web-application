node{
  def mavenHome = tool name: '3.9.14'

  configFileProvider([configFile(fileId: 'f14dd0cf-733e-4c8f-a93d-3d76e9bfef4a', variable: 'MAVEN_SETTINGS')]) {

    stage('1.CodeClone'){
      git credentialsId: 'GitHub Credentials', url: 'https://github.com/tolu-env/maven-web-application.git'
    }
    stage('2MavenBuild'){
      sh "${mavenHome}/bin/mvn package -s $MAVEN_SETTINGS"
    }
    stage('3codeQuality'){
      sh "${mavenHome}/bin/mvn sonar:sonar -s $MAVEN_SETTINGS"
    }
    stage('4UploadArtifacts'){
      sh "${mavenHome}/bin/mvn deploy -s $MAVEN_SETTINGS"
    }
    stage('6Manualapproval'){
      sh "echo 'ready for review'"
      timeout(time:5, unit:'HOURS') {
        input message: 'Application ready for deployment, Please review and approve'
      }
    }

  }
}
